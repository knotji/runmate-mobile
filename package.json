{
  "name": "runmate-mobile",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test.e2e": "cypress run",
    "test.unit": "vitest",
    "lint": "eslint",
    "android:signing:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-android-signing.ps1",
    "android:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-android-release.ps1 -Artifact both",
    "android:release:apk": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-android-release.ps1 -Artifact apk",
    "android:release:aab": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-android-release.ps1 -Artifact aab",
    "android:distribute": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/distribute-android-release.ps1"
  },
  "dependencies": {
    "@capacitor-firebase/crashlytics": "^8.3.0",
    "@capacitor/app": "8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/core": "8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.5",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "8.0.3",
    "@capgo/capacitor-health": "^8.9.3",
    "@fontsource/ibm-plex-sans-thai": "^5.2.8",
    "@ionic/react": "^8.5.0",
    "@ionic/react-router": "^8.5.0",
    "@supabase/supabase-js": "^2.110.7",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "ionicons": "^7.4.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "8.4.2",
    "@testing-library/dom": ">=7.21.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-legacy": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.1",
    "cypress": "^13.5.0",
    "eslint": "^9.20.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^22.1.0",
    "terser": "^5.4.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^5.0.0",
    "vitest": "^0.34.6"
  },
  "description": "An Ionic project"
}
