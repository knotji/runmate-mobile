<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@android:color/transparent"
    android:padding="14dp">

    <FrameLayout
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/widget_icon_bg">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_stat_runmate" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODAY'S PLAN"
            android:textColor="#FF2474B2"
            android:textSize="9sp"
            android:textStyle="bold"
            android:shadowColor="#66FFFFFF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/widget_workout_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="No Plan Yet"
            android:textColor="#FF172C49"
            android:textSize="14sp"
            android:textStyle="bold"
            android:shadowColor="#66FFFFFF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/widget_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""
            android:textColor="#FF667B92"
            android:textSize="10sp"
            android:shadowColor="#66FFFFFF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="3" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_status_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/widget_badge_rest"
        android:paddingLeft="9dp"
        android:paddingRight="9dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="—"
        android:textColor="#FF667B92"
        android:textSize="9sp"
        android:textStyle="bold" />

</LinearLayout>
